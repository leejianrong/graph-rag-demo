# Example environment for the Graph RAG demo.
# Copy to `.env` (gitignored) and adjust. Defaults match the docker-compose
# service names used by later slices (minio, elasticsearch, kafka).

# --- MinIO / ObjectStore ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=documents

# --- Elasticsearch / DocumentStore + EntityStore ---
ELASTICSEARCH_URL=http://elasticsearch:9200
DOCUMENTS_INDEX=documents
ENTITIES_INDEX=entities

# --- Kafka / messaging seam ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
INGEST_TRIGGER_TOPIC=ingest-triggers

# --- LLM client (V3, ADR-0008) ---
# Provider-agnostic via LiteLLM. The model is a LiteLLM model string, so any
# OpenAI-compatible endpoint (incl. DeepSeek) is swappable here. Per-stage model:
COREF_MODEL=gpt-4o-mini
KG_BUILD_MODEL=gpt-4o-mini
# Persistent response cache dir (gitignored). A cache hit costs $0 / no API call.
LLM_CACHE_DIR=.cache/llm
# Structured-output retries on parse/validation failure before raising.
LLM_MAX_RETRIES=2
# API key STRICTLY from the environment — never commit a real key. Left blank so
# the fakes-only fast suite needs no key; only a real provider call does. For the
# gpt-4o-mini default set your OpenAI key; point COREF_MODEL elsewhere + set that
# provider's key to swap.
OPENAI_API_KEY=

# --- Logging seam ---
LOG_LEVEL=INFO
