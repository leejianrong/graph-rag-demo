# Example environment for the Graph RAG demo.
# Copy to `.env` (gitignored) and adjust. Defaults match the docker-compose
# service names used by later slices (minio, elasticsearch, kafka).

# --- MinIO / ObjectStore ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=documents

# --- Elasticsearch / DocumentStore + EntityStore ---
ELASTICSEARCH_URL=http://elasticsearch:9200
DOCUMENTS_INDEX=documents
ENTITIES_INDEX=entities

# --- Kafka / messaging seam ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
INGEST_TRIGGER_TOPIC=ingest-triggers

# --- Logging seam ---
LOG_LEVEL=INFO
